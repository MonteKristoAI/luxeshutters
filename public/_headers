  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://dashboard.retellai.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://primary-production-5fdce.up.railway.app wss://dashboard.retellai.com; frame-src https://www.google.com

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=31536000, immutable

/sitemap.xml
